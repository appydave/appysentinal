# Machine identifier baked into every Signal envelope.
# Defaults to the value the CLI captured at scaffold time.
MACHINE_NAME={{MACHINE_NAME}}

# Pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Add transport / interface / storage env vars below as recipes are wired in.
# Examples:
# HTTP_PUSH_URL=https://example.com/ingest
# HTTP_PUSH_TOKEN=xxxxx
# MCP_SOCKET_PATH=/tmp/{{PROJECT_NAME}}.sock
