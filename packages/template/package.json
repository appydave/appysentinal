{
  "name": "@appydave/appysentinel-template",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal AppySentinel scaffold — the template that create-appysentinel copies into new projects",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "test": "echo 'template has no tests by default' && exit 0",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'template lint stub' && exit 0"
  },
  "dependencies": {
    "@appydave/appysentinel-core": "workspace:*"
  },
  "devDependencies": {
    "@appydave/appysentinel-config": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  }
}
